# ============================================================
# DOCUMENT READING SERVICES — Environment Configuration
# ============================================================

# --- Google Gemini API (Free Tier) ---
GEMINI_API_KEY=Your_API_KEY
GEMINI_MODEL=gemini-2.5-flash          # Free tier model
GEMINI_MAX_RETRIES=3
GEMINI_TIMEOUT_SECONDS=30

# --- OCR Settings ---
# TESSERACT_PATH=/usr/bin/tesseract       # Linux default
TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe  # Windows
TESSERACT_LANG=eng+hin                  # English + Hindi

# --- API Settings ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
SECRET_KEY=Your_Secret_Key
API_VERSION=v1

# --- File Upload Limits ---
MAX_FILE_SIZE_MB=10
ALLOWED_FORMATS=jpg,jpeg,png,pdf,webp
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# --- Database ---
# DATABASE_URL=sqlite+aiosqlite:///./doc_reader.db
DATABASE_URL=postgresql+asyncpg://postgres:pass@localhost/docreader

# --- Redis Cache (optional) ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# --- Document Expiry Rules (days) ---
INCOME_CERTIFICATE_VALIDITY_DAYS=365
DOMICILE_CERTIFICATE_VALIDITY_DAYS=1825   # 5 years
CASTE_CERTIFICATE_VALIDITY_DAYS=1825
EWS_CERTIFICATE_VALIDITY_DAYS=365

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30
